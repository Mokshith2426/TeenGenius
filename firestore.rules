rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    match /test/connection {
      allow read: if true;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt'])
        && data.uid == request.auth.uid
        && data.email is string
        && data.createdAt == request.time
        && (data.get('displayName', '') is string)
        && (data.get('isOnline', false) is bool)
        && (data.get('friendIds', []) is list)
        && (data.get('xp', 0) is int)
        && (data.get('badges', []) is list);
    }

    // --- Chat Validation ---
    function isValidChat(data) {
      return data.keys().hasAll(['type', 'memberIds', 'lastUpdatedAt'])
        && data.type in ['private', 'group']
        && data.memberIds is list
        && data.memberIds.size() >= 1
        && data.memberIds.size() <= 100
        && request.auth.uid in data.memberIds
        && data.lastUpdatedAt == request.time;
    }

    // --- Message Validation ---
    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'content', 'type', 'timestamp'])
        && isValidId(data.chatId)
        && data.senderId == request.auth.uid
        && data.content is string
        && data.content.size() <= 5000
        && data.type in ['text', 'image', 'video-call-status']
        && data.timestamp == request.time;
    }

    // --- StudyGroup Validation ---
    function isValidStudyGroup(data) {
      return data.keys().hasAll(['name', 'ownerId', 'memberIds', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.ownerId == request.auth.uid
        && data.memberIds is list
        && data.memberIds.size() > 0
        && data.createdAt == request.time
        && (data.get('scratchpad', '') is string)
        && (data.get('whiteboardLines', []) is list)
        && (data.get('tasks', []) is list);
    }

    // --- Note Validation ---
    function isValidNote(data) {
      return data.keys().hasAll(['groupId', 'authorId', 'type', 'timestamp'])
        && isValidId(data.groupId)
        && data.authorId == request.auth.uid
        && data.type in ['text', 'image']
        && data.timestamp == request.time
        && (data.get('title', '') is string)
        && (data.get('content', '') is string);
    }

    function isValidDoubt(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'createdAt', 'isSolved', 'answers'])
        && data.authorId == request.auth.uid
        && data.title is string
        && data.content is string
        && data.createdAt == request.time
        && data.isSolved is bool
        && data.answers is list;
    }

    function isValidModule(data) {
      return data.keys().hasAll(['title', 'createdBy', 'createdAt', 'completedBy'])
        && data.title is string
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time
        && data.completedBy is list;
    }

    // --- FriendRequest Validation ---
    function isValidFriendRequest(data) {
      return data.keys().hasAll(['fromId', 'toId', 'status', 'timestamp'])
        && data.fromId == request.auth.uid
        && data.status == 'pending'
        && data.timestamp == request.time
        && isValidId(data.toId);
    }

    // --- Timetable Validation ---
    function isValidTimetable(data) {
      return data.keys().hasAll(['userId', 'timetableData', 'createdAt'])
        && data.userId == request.auth.uid
        && data.createdAt == request.time
        && data.timetableData is map
        && (data.get('subjects', []) is list)
        && (data.get('hoursPerDay', '') is string)
        && (data.get('preferences', '') is string);
    }

    // --- AIMessage Validation ---
    function isValidAIMessage(data) {
      return data.keys().hasAll(['role', 'content', 'timestamp'])
        && data.role in ['user', 'assistant']
        && data.content is string
        && data.timestamp == request.time
        && (data.get('image', '') is string)
        && (data.get('status', 'delivered') in ['sending', 'delivered', 'read', 'processed']);
    }

    // --- HomeworkSolution Validation ---
    function isValidHomeworkSolution(data) {
      return data.keys().hasAll(['userId', 'subject', 'question', 'solution', 'createdAt'])
        && data.userId == request.auth.uid
        && data.subject is string
        && data.question is string
        && data.solution is string
        && data.createdAt == request.time
        && (data.get('imageUrl', '') is string);
    }

    function isValidAIChat(data) {
      return data.keys().hasAll(['userId', 'lastUpdatedAt'])
        && data.userId == request.auth.uid
        && data.lastUpdatedAt == request.time
        && (data.get('title', '') is string)
        && (data.get('lastMessage', '') is string);
    }



    // --- Collection Matches ---

    match /aiChats/{chatId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAIChat(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'lastMessage', 'lastUpdatedAt'])
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/aiChats/$(chatId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && isValidAIMessage(incoming()) && (
          get(/databases/$(database)/documents/aiChats/$(chatId)).data.userId == request.auth.uid
        );
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/aiChats/$(chatId)).data.userId == request.auth.uid
        ) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        );
      }
    }



    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isOwner(userId) ? (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'isOnline', 'friendIds', 'publicKey', 'xp', 'badges', 'aiUses', 'solvedDoubts', 'modulesCompleted', 'quizzesCompleted', 'focusSessionsCompleted']) &&
          (!incoming().keys().hasAny(['xp']) || (
            incoming().xp is int &&
            (incoming().xp <= existing().get('xp', 100) + 100)
          )) &&
          (!incoming().keys().hasAny(['aiUses']) || (
            incoming().aiUses is int &&
            (incoming().aiUses <= existing().get('aiUses', 0) + 5)
          )) &&
          (!incoming().keys().hasAny(['solvedDoubts']) || (
            incoming().solvedDoubts is int &&
            (incoming().solvedDoubts <= existing().get('solvedDoubts', 0) + 5)
          )) &&
          (!incoming().keys().hasAny(['modulesCompleted']) || (
            incoming().modulesCompleted is int &&
            (incoming().modulesCompleted <= existing().get('modulesCompleted', 0) + 5)
          )) &&
          (!incoming().keys().hasAny(['quizzesCompleted']) || (
            incoming().quizzesCompleted is int &&
            (incoming().quizzesCompleted <= existing().get('quizzesCompleted', 0) + 5)
          )) &&
          (!incoming().keys().hasAny(['focusSessionsCompleted']) || (
            incoming().focusSessionsCompleted is int &&
            (incoming().focusSessionsCompleted <= existing().get('focusSessionsCompleted', 0) + 5)
          ))
        ) : (
          incoming().diff(existing()).affectedKeys().hasOnly(['friendIds']) &&
          (
            // If they are adding themselves (arrayUnion)
            (incoming().friendIds.hasAll(existing().get('friendIds', [])) && request.auth.uid in incoming().friendIds)
            ||
            // If they are removing themselves (arrayRemove)
            (existing().get('friendIds', []).hasAll(incoming().friendIds) && !(request.auth.uid in incoming().friendIds))
          )
        )
      );
    }

    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /studySessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in existing().memberIds;
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().memberIds && (
        incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastUpdatedAt', 'memberIds'])
      );

      match /participants/{userId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
        allow write: if isOwner(userId) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
      }

      match /typing/{userId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
        allow write: if isOwner(userId) && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
        allow create: if isSignedIn() && isValidMessage(incoming()) && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds
        );
        allow update: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds && (
          incoming().diff(existing()).affectedKeys().hasOnly(['reactions'])
        );
      }
    }

    match /studyGroups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidStudyGroup(incoming());
      allow update: if isSignedIn() && (
        (request.auth.uid in existing().memberIds && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'memberIds', 'scratchpad', 'whiteboardLines', 'tasks'])
        ))
        ||
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['memberIds']) &&
          incoming().memberIds.size() == existing().memberIds.size() + 1 &&
          incoming().memberIds.hasAll(existing().memberIds) &&
          request.auth.uid in incoming().memberIds
        )
      );

      match /notes/{noteId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.memberIds);
        allow create: if isSignedIn() && isValidNote(incoming()) && (
          request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.memberIds
        );
        allow delete: if isSignedIn() && (
          resource.data.authorId == request.auth.uid || 
          request.auth.uid == get(/databases/$(database)/documents/studyGroups/$(groupId)).data.ownerId
        );
      }

      match /doubts/{doubtId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.memberIds);
        allow create: if isSignedIn() && isValidDoubt(incoming()) && (
          request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.memberIds
        );
        allow update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.memberIds);
      }

      match /modules/{moduleId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.memberIds);
        allow create: if isSignedIn() && isValidModule(incoming()) && (
          request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.memberIds
        );
        allow update, delete: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/studyGroups/$(groupId)).data.memberIds);
      }
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == existing().fromId || request.auth.uid == existing().toId);
      allow create: if isSignedIn() && isValidFriendRequest(incoming());
      allow update: if isSignedIn() && request.auth.uid == existing().toId && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['accepted', 'declined']
      );
      allow delete: if isSignedIn() && (request.auth.uid == existing().fromId || request.auth.uid == existing().toId);
    }

    match /timetables/{timetableId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidTimetable(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidTimetable(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    match /homeworkSolutions/{solutionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidHomeworkSolution(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidHomeworkSolution(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /notesLab/{noteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /feedbacks/{feedbackId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
    }

    match /performance_diagnostics/{logId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
    }

    match /analytics_events/{eventId} {
      allow create, read: if true;
    }

  }
}
